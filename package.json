{
	"name": "ship",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"ui"
	],
	"scripts": {
		"dev": "pnpm --filter ship-ui dev",
		"build": "pnpm --filter ship-ui build",
		"lint": "pnpx @biomejs/biome lint --write",
		"lint:fix": "pnpm --filter ship-ui lint:fix",
		"ts": "pnpm --filter ship-ui ts",
		"check": "pnpx @biomejs/biome check --write",
		"fmt": "pnpx @biomejs/biome format --write"
	},
	"keywords": [
		"messenger",
		"secure"
	],
	"author": "aplxd",
	"license": "ISC",
	"description": "ship client",
	"devDependencies": {
		"@biomejs/biome": "^2.4.7",
		"@tailwindcss/postcss": "^4.1.18",
		"@tauri-apps/cli": "^2.7.1",
		"postcss": "^8.5.6",
		"tailwindcss": "^4.1.18"
	}
}